# DMS Site — Environment Configuration
# Copy to .env and edit:  cp .env.example .env
#
# VITE_* vars are available to both the client (import.meta.env) and server.
# Non-VITE vars are server-only (never included in client bundles).

# ─── Site Configuration ───────────────────────────────
# Which DMS site to load (used by client App.jsx and SSR server)
VITE_DMS_APP=avail
VITE_DMS_TYPE=site
VITE_DMS_BASE_URL=/list
VITE_DMS_AUTH_PATH=/auth
VITE_DMS_PG_ENVS=npmrds2

# ─── API Host ─────────────────────────────────────────
# Falcor API endpoint (client connects here for data)
VITE_API_HOST=https://graph.availabs.org
VITE_DAMA_HOST=https://graph.availabs.org
# ─── Server ───────────────────────────────────────────
PORT=3001

# DMS database config (filename from dms-server/src/db/configs/, without .config.json)
DMS_DB_ENV=dms-sqlite

# Auth database config
DMS_AUTH_DB_ENV=dms-sqlite

# Request logging (1 = enabled, 0 = disabled)
DMS_LOG_REQUESTS=0

# Split table mode: 'legacy' or 'per-app'
# DMS_SPLIT_MODE=legacy

# JWT secret (generate a random string for production)
JWT_SECRET=

# ─── App-owned DAMA datatypes ─────────────────────────
# Path to the registration module that wires app-specific datatype plugins
# (data-types/<name>/) into dms-server at boot. The server require()s this
# file and calls its default export with { registerDatatype }.
# DMS_EXTRA_DATATYPES=/abs/path/to/dms-template/server/register-datatypes.js

# ─── SSR ──────────────────────────────────────────────
# Set to 1 to enable server-side rendering in dms-server
# DMS_SSR=1

# ─── File storage ─────────────────────────────────────
# Backend for uploaded files / dataset exports / pmtiles cache.
#   'local' (default) — store on the server's filesystem
#   's3'             — S3-compatible object storage (requires @aws-sdk/client-s3)
# DMS_STORAGE_TYPE=local

# Local backend — root directory (default: dms-server/var/dama-files)
# DAMA_SERVER_FILESTORAGE_PATH=

# S3 backend — required when DMS_STORAGE_TYPE=s3
# AWS_ENDPOINT_URL=          # optional override for S3-compatible providers (DigitalOcean, MinIO, etc.)
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET=        # bucket name
# AWS_BUCKET_URL=            # base URL for public asset links, e.g. https://<bucket>.s3.<region>.amazonaws.com

# ─── SMTP (optional — email features are no-ops without these) ──
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=false
