{
  "name": "dms-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "analyze": "npx vite-bundle-analyzer",
    "dev": "vite",
    "deploy": "netlify deploy --site ccf0fbba-fd28-4293-af14-05243c2ac614 --prod --dir=dist",
    "deploy-b3nson": "netlify deploy --site e38244d6-14d7-47bc-a17a-8bdcf68b5ad1 --prod --dir=dist",
    "deploy-ctp": "netlify deploy --site dcc24f65-8921-46fb-8827-0059571b9289 --prod --dir=dist",
    "deploy-wcdb": "netlify deploy --site 0d9002a2-ed81-466e-88b9-837bf150f6e0 --prod --dir=dist",
    "deploy-devmny": "netlify deploy --site 4f81b618-a3cf-4f79-baa3-3d4e82edef3a --prod --dir=dist",
    "deploy-dmsdocs": "netlify deploy --site d7484307-0a49-442a-b37a-d91e31968f20 --prod --dir=dist",
    "deploy-mnyprod": "netlify deploy --site 879eb9bb-aff5-47b9-95ba-65e9fd5ce7dc --prod --dir=dist",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "vite",
    "server": "npm start --prefix src/dms/packages/dms-server",
    "server:dev": "npm run dev --prefix src/dms/packages/dms-server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-ssr.jsx --outDir dist/server",
    "build:ssr": "npm run build:client && npm run build:server",
    "clean": "rm -rf node_modules package-lock.json src/dms/node_modules src/dms/package-lock.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@availabs/dms": "file:./src/dms/packages/dms",
    "@availabs/dms-server": "file:./src/dms/packages/dms-server",
    "@carbon/icons-react": "11.76.0",
    "lodash-es": "^4.17.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.1.18",
    "vite": "~7.2.7",
    "vite-bundle-analyzer": "^1.3.2",
    "vitest": "^4.1.2"
  }
}
