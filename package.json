{
  "name": "dms-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "analyze": "npx vite-bundle-analyzer",
    "dev": "vite",
    "deploy": "netlify deploy --site ccf0fbba-fd28-4293-af14-05243c2ac614 --prod",
    "deploy-b3nson": "netlify deploy --site e38244d6-14d7-47bc-a17a-8bdcf68b5ad1 --prod",
    "deploy-wcdb": "netlify deploy --site 0d9002a2-ed81-466e-88b9-837bf150f6e0 --prod",
    "deploy-dmsdocs": "netlify deploy --site d7484307-0a49-442a-b37a-d91e31968f20 --prod",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "vite",
    "server": "npm start --prefix src/dms/packages/dms-server",
    "server:dev": "npm run dev --prefix src/dms/packages/dms-server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-ssr.jsx --outDir dist/server",
    "build:ssr": "npm run build:client && npm run build:server",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@availabs/dms": "^0.1.12",
    "@carbon/icons-react": "^11.71.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "1.0.0",
    "compression": "^1.8.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "express": "^5.2.1",
    "globals": "^15.11.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.1.18",
    "vite": "~7.2.7",
    "vite-bundle-analyzer": "^1.3.2",
    "vitest": "^4.1.2"
  }
}
